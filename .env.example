FRED_API_KEY=your_32_character_fred_api_key
DATA_SOURCE=free
# FMP mode only:
# FMP_API_KEY=your_fmp_api_key

# X automation (safe defaults)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/responses
LLM_MODEL=gpt-5-mini
NEWS_API_KEY=
SITE_URL=https://macro-crisis-dashboard.vercel.app
CRON_SECRET=
ADMIN_SECRET=
DRY_RUN=true
AUTO_POST_ENABLED=false

# Local uses data/x-automation/state.json. Vercel requires Upstash REST.
X_AUTOMATION_STORAGE=file
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SEC asks automated clients to identify themselves.
SEC_USER_AGENT=Macro Crisis Dashboard admin@example.com
